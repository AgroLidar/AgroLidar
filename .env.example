# Ruta del registro de modelos (JSON) para promotion/auditoría.
MODEL_REGISTRY_PATH=outputs/registry/registry.json

# Directorio donde train/retrain guardan checkpoints.
CHECKPOINT_DIR=outputs/checkpoints/

# Directorio base de datos para entrenamiento/evaluación.
DATA_DIR=data/

# Nivel de logging del pipeline (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Si true, ejecuta modo seguro sin promotion/despliegue real.
DRY_RUN=false
