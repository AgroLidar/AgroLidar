solid tractor_proxy
  facet normal 0 0 1
    outer loop
      vertex -1 0 2
      vertex 1 0 2
      vertex 0 1 2
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex -1 0 -2
      vertex 0 1 -2
      vertex 1 0 -2
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex 1 0 -2
      vertex 1 0 2
      vertex 0 1 0
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex -1 0 -2
      vertex 0 1 0
      vertex -1 0 2
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex -1 0 -2
      vertex -1 0 2
      vertex 1 0 2
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex -1 0 -2
      vertex 1 0 2
      vertex 1 0 -2
    endloop
  endfacet
endsolid tractor_proxy
